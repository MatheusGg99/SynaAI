# Syna Environment Variables
# Copy this file to .env and fill in your keys

# Groq API (required for web search, link reading, vision)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API (optional, for additional fallback models)
OPENROUTER_API_KEY=your_openrouter_key_here

# No need for local KoboldCPP keys – it runs without authentication
